# XcodeMCP CLI Configuration
# Copy this file to .env and configure as needed

# No API keys required - XcodeMCP uses local Xcode installation
# The MCP server must be configured in your Claude Desktop settings

# Optional: Default project path (used when --xcodeproj not specified)
# XCODE_DEFAULT_PROJECT=/path/to/your/MyApp.xcodeproj

# Optional: Default destination for builds and tests
# XCODE_DEFAULT_DESTINATION=iPhone 15 Pro

# Optional: Timeout for long-running operations (in seconds)
# XCODE_TIMEOUT=300

# Debug mode (set to true for verbose logging)
# DEBUG=false
