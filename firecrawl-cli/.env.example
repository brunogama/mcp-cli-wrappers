# Firecrawl MCP CLI Configuration
# Copy to .env and fill in values: cp .env.example .env

# =============================================================================
# REQUIRED
# =============================================================================

# Firecrawl API Key (get from https://firecrawl.dev)
FIRECRAWL_API_KEY=fc-your-api-key-here

# =============================================================================
# OPTIONAL
# =============================================================================

# Custom API URL (for self-hosted instances)
# FIRECRAWL_API_URL=http://localhost:3000

# MCP Transport type (stdio or http)
# FIRECRAWL_TRANSPORT=stdio

# =============================================================================
# RETRY SETTINGS
# =============================================================================

# Maximum retry attempts for failed requests
# FIRECRAWL_RETRY_MAX_ATTEMPTS=3

# Initial delay between retries (milliseconds)
# FIRECRAWL_RETRY_INITIAL_DELAY=1000

# Maximum delay between retries (milliseconds)
# FIRECRAWL_RETRY_MAX_DELAY=10000

# Backoff multiplier for exponential retry
# FIRECRAWL_RETRY_BACKOFF_FACTOR=2

# =============================================================================
# CREDIT MONITORING
# =============================================================================

# Warning threshold for API credits
# FIRECRAWL_CREDIT_WARNING_THRESHOLD=1000

# Critical threshold for API credits
# FIRECRAWL_CREDIT_CRITICAL_THRESHOLD=100
