# Sequential Thinking MCP CLI Configuration
# Copy this file to .env and configure as needed

# ===== Optional Configuration =====

# Enable debug output (true/false)
DEBUG=false

# Request timeout in seconds
TIMEOUT=30

# ===== MCP Server Configuration =====

# Override MCP server URL (default: uses npx transport)
# MCP_SERVER_URL=http://localhost:8080

# ===== Notes =====
# Sequential Thinking MCP uses npx transport by default.
# No API keys are required for basic operation.
# The npx package is: @anthropics/sequential-thinking-mcp
