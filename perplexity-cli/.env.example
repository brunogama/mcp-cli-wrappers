# Perplexity CLI Configuration
# Copy this file to .env and fill in your values

# Required: Your Perplexity API Key
# Get it at: https://www.perplexity.ai/account/api/group
PERPLEXITY_API_KEY=your_api_key_here

# Optional: Custom base URL (default: https://api.perplexity.ai)
# PERPLEXITY_BASE_URL=https://api.perplexity.ai

# Optional: Request timeout in milliseconds (default: 300000 = 5 minutes)
# Increase for long research queries
# PERPLEXITY_TIMEOUT_MS=600000

# Optional: Proxy URL (for corporate networks)
# PERPLEXITY_PROXY=https://your-proxy-host:8080
# PERPLEXITY_PROXY=https://username:password@your-proxy-host:8080

# Alternative proxy environment variables (checked if PERPLEXITY_PROXY not set)
# HTTPS_PROXY=https://your-proxy-host:8080
# HTTP_PROXY=http://your-proxy-host:8080
